<Window x:Class="SplitWalls.UI.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="SplitWalls — Profile Editor"
        Width="1000" Height="680"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <x:Array x:Key="ProfileTypes" Type="{x:Type sys:String}"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <sys:String>standard</sys:String>
            <sys:String>U</sys:String>
            <sys:String>L_left</sys:String>
            <sys:String>L_right</sys:String>
            <sys:String>T</sys:String>
            <sys:String>I</sys:String>
            <sys:String>borde</sys:String>
        </x:Array>
        <x:Array x:Key="FireRatingTypes" Type="{x:Type sys:String}"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <sys:String>none</sys:String>
            <sys:String>1hr</sys:String>
            <sys:String>2hr</sys:String>
            <sys:String>3hr</sys:String>
        </x:Array>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310" MinWidth="260"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT: Form panel ── -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">

                <!-- Profile name -->
                <TextBlock Text="Profile Name" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,6"/>

                <!-- Strategy -->
                <TextBlock Text="Strategy" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <ComboBox SelectedValue="{Binding Strategy}"
                          ItemsSource="{Binding Strategies}"
                          Margin="0,0,0,8"/>

                <!-- Defaults -->
                <GroupBox Header="Defaults" Margin="0,0,0,8" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Panel Width (mm)"
                                   VerticalAlignment="Center" Margin="0,4,4,4"/>
                        <xctk:DoubleUpDown Grid.Row="0" Grid.Column="1"
                            Value="{Binding PanelWidthMm, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="100" Maximum="5000" Increment="10" FormatString="0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Separator (mm)"
                                   VerticalAlignment="Center" Margin="0,4,4,4"/>
                        <xctk:DoubleUpDown Grid.Row="1" Grid.Column="1"
                            Value="{Binding SeparatorWidthMm, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="0" Maximum="50" Increment="1" FormatString="0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Wall Height (mm)"
                                   VerticalAlignment="Center" Margin="0,4,4,4"/>
                        <xctk:DoubleUpDown Grid.Row="2" Grid.Column="1"
                            Value="{Binding WallHeightMm, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="500" Maximum="10000" Increment="10" FormatString="0"/>

                        <CheckBox Grid.Row="3" Grid.ColumnSpan="2"
                            Content="Disable Wall Joins"
                            IsChecked="{Binding DisableWallJoins}"
                            Margin="0,6,0,2"/>
                    </Grid>
                </GroupBox>

                <!-- Split rule -->
                <GroupBox Header="Split Rule" Margin="0,0,0,8" Padding="6">
                    <StackPanel>
                        <TextBlock Text="Method" Margin="0,0,0,2"/>
                        <ComboBox SelectedValue="{Binding SplitMethod}"
                                  ItemsSource="{Binding SplitMethods}"
                                  Margin="0,0,0,6"/>
                        <Button Content="Auto-Split Preview"
                                Command="{Binding AutoSplitCommand}"
                                HorizontalAlignment="Left" Padding="8,3"/>
                    </StackPanel>
                </GroupBox>

                <!-- Segments -->
                <GroupBox Header="Segments" Margin="0,0,0,8" Padding="4">
                    <DataGrid ItemsSource="{Binding Segments}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowHeaderWidth="0"
                              Height="140"
                              GridLinesVisibility="Horizontal"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="28" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Width" Binding="{Binding WidthMm, StringFormat=0}" Width="52"/>
                            <DataGridComboBoxColumn Header="Profile" Width="72"
                                SelectedValueBinding="{Binding Profile, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{StaticResource ProfileTypes}"/>
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                            <DataGridComboBoxColumn Header="Fire" Width="48"
                                SelectedValueBinding="{Binding FireRating, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{StaticResource FireRatingTypes}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <!-- Openings -->
                <GroupBox Header="Openings" Margin="0,0,0,8" Padding="6">
                    <StackPanel>
                        <Button Content="+ Add Opening"
                                Command="{Binding AddOpeningCommand}"
                                HorizontalAlignment="Left" Padding="8,3" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Openings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="11">
                                                <Run Text="{Binding Type}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding WidthMm, StringFormat=0}"/>
                                                <Run Text="×"/>
                                                <Run Text="{Binding HeightMm, StringFormat=0}"/>
                                                <Run Text="mm"/>
                                            </TextBlock>
                                            <Button Grid.Column="1" Content="&#x2715;"
                                                FontSize="10" Padding="2,0"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.RemoveOpeningCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                    <Button Content="New"     Command="{Binding NewCommand}"     Width="55" Margin="0,0,4,0" Padding="4,3"/>
                    <Button Content="Load"    Command="{Binding LoadCommand}"    Width="55" Margin="0,0,4,0" Padding="4,3"/>
                    <Button Content="Save"    Command="{Binding SaveCommand}"    Width="55" Margin="0,0,4,0" Padding="4,3"/>
                    <Button Content="Save As" Command="{Binding SaveAsCommand}"  Width="60" Padding="4,3"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- ── RIGHT: Canvas preview ── -->
        <Border Grid.Column="2" BorderBrush="#AAA" BorderThickness="1" Margin="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="2D Preview (read-only)"
                           FontSize="11" Foreground="#666"
                           Margin="6,4,0,2"/>
                <Canvas Grid.Row="1" x:Name="PreviewCanvas"
                        Background="White" ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged"/>
            </Grid>
        </Border>

    </Grid>
</Window>
